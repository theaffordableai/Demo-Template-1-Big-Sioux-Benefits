---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config/site.config";
const breadcrumbs = [{ name: "Home", url: site.domain }, { name: "Reviews", url: `${site.domain}/reviews` }];
const reviews = [
  ["They found me a plan that kept both my Sanford doctors and saved me $60 a month. I didn't know Iowa plans were even an option until they showed me.", "Karen M., Brandon, SD"],
  ["No pressure, just honest help. They sat with my husband and me and explained everything in plain English.", "Dennis & Carol R., Sioux Falls"],
  ["I dreaded turning 65 and the Medicare maze. They made it simple and handled the paperwork. Highly recommend.", "Linda T., Harrisburg, SD"],
  ["When a claim got denied they jumped in and helped me appeal it. You don't get that from an 800 number.", "Roger P., Sioux Center, IA"],
];
---
<BaseLayout title="Reviews — Big Sioux Benefits" description="See what Sioux Falls-area clients say about Big Sioux Benefits. 4.9★ across 212+ reviews." pageType="service" path="/reviews" {breadcrumbs}>
  <section class="section"><div class="wrap" style="max-width:820px;">
    <p class="eyebrow">Reviews</p>
    <h1>What our neighbors say</h1>
    <p style="font-size:1.18rem;">⭐⭐⭐⭐⭐ <strong>4.9 out of 5</strong> across 212+ Google &amp; Facebook reviews.</p>
    <div style="margin-top:2rem;">
      {reviews.map(([q, who]) => (
        <blockquote class="card" style="border-left:4px solid var(--gold);margin:0 0 1.2rem;">
          <p style="font-family:var(--sans);font-size:1.12rem;">"{q}"</p>
          <p class="muted" style="margin:0;">— {who} · ★★★★★</p>
        </blockquote>
      ))}
    </div>
  </div></section>
  <section class="section soft"><div class="wrap" style="text-align:center;">
    <h2>Join hundreds of happy neighbors</h2>
    <p><a class="btn btn-primary" href="/contact">Book a free consultation →</a></p>
  </div></section>
</BaseLayout>
