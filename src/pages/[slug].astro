---
import BaseLayout from "../layouts/BaseLayout.astro";
import Tool from "../components/Tool.astro";
import { allEntries, type Entry } from "../lib/content";
import { site } from "../config/site.config";

export function getStaticPaths() {
  return allEntries.map((e) => ({ params: { slug: e.slug }, props: { entry: e } }));
}
const { entry } = Astro.props as { entry: Entry };

// Each tool page gets its real, interactive, WebMCP-backed calculator.
const TOOL_BY_SLUG: Record<string, string> = {
  "eligibility-calculator": "medicare_eligibility",
  "enrollment-timeline": "medicare_eligibility",
  "part-b-penalty": "part_b_penalty",
  "part-d-penalty": "part_d_penalty",
  "premium-calculator": "irmaa_calculator",
  "provider-directory": "medicare_plan_finder",
};
const toolName =
  entry.kind === "tool" ? (TOOL_BY_SLUG[entry.slug] ?? "medicare_plan_finder")
  : entry.kind === "coverage" ? "medicare_plan_finder"
  : null;
const pageType = entry.kind === "education" ? "article" : entry.kind === "tool" ? "tool" : "service";
const eyebrow = entry.kind === "coverage" ? "Plans & Coverage" : entry.kind === "education" ? "Medicare 101" : "Free Tools";
const breadcrumbs = [
  { name: "Home", url: site.domain },
  { name: eyebrow, url: `${site.domain}/${entry.slug}` },
  { name: entry.h1, url: `${site.domain}/${entry.slug}` },
];
---
<BaseLayout title={entry.title} description={entry.summary} pageType={pageType} path={`/${entry.slug}`} faqs={entry.faqs} {breadcrumbs}>
  <section class="section"><div class="wrap" style="max-width:820px;">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{entry.h1}</h1>
    <p style="font-size:1.18rem;">{entry.intro}</p>
    <p><a class="btn btn-primary" href="/contact">Get free local help →</a> &nbsp; <a class="btn btn-ghost" href={`tel:${site.brand.phoneHref}`}>{site.brand.phone}</a></p>
  </div></section>

  {entry.sections.length > 0 && (
    <section class="section soft"><div class="wrap" style="max-width:820px;">
      {entry.sections.map((s) => (
        <div style="margin-bottom:1.5rem;"><h2>{s.h}</h2><p>{s.body}</p></div>
      ))}
    </div></section>
  )}

  {toolName && (
    <section class="section soft"><div class="wrap"><Tool tool={toolName} /></div></section>
  )}

  <section class="section faq"><div class="wrap" style="max-width:820px;">
    <h2>Questions, answered</h2>
    {entry.faqs.map((f) => (<details><summary>{f.q}</summary><p>{f.a}</p></details>))}
  </div></section>

  <section class="section soft"><div class="wrap" style="text-align:center;">
    <h2>Talk to a local Sioux Falls advisor</h2>
    <p class="muted">Free, no pressure — we compare your options for you.</p>
    <p><a class="btn btn-primary" href="/contact">Book a free consultation →</a></p>
  </div></section>
</BaseLayout>
