---
import BaseLayout from "../layouts/BaseLayout.astro";
import Tool from "../components/Tool.astro";
import CountyData from "../components/CountyData.astro";
import { siouxCenter as d } from "../data/sioux-center";
import { SOURCES } from "../data/sioux-falls";
import { site } from "../config/site.config";

// Real brain data via src/data/sioux-center.ts (CMS PY2026, CMS enrollment, CDC PLACES, NPPES).
const title = "2026 Medicare Advantage Plans in Sioux Center & NW Iowa (Sioux County)";
const description = `Sioux County, IA has ${d.market.stateTotalPlans} Medicare Advantage plans for 2026 — more choice than across the border in South Dakota. Real CMS plan data, local health stats, and a live plan finder from Big Sioux Benefits.`;
const faqs = [
  { q: "How many Medicare Advantage plans are available in Sioux County, Iowa for 2026?", a: `Sioux County, IA has ${d.market.stateTotalPlans} Medicare Advantage plans with drug coverage for 2026 — including ${d.market.zeroPremiumCount} at $0 premium — from carriers including Humana, Aetna, Align (Sanford), Wellcare, UnitedHealthcare, and Iowa Health Advantage. That's notably more choice than just across the border in South Dakota.` },
  { q: "Why does NW Iowa have more Medicare Advantage plans than Sioux Falls?", a: `Iowa's Medicare Advantage market is more competitive: Sioux County offers ${d.market.stateTotalPlans} plans versus around 11 in the Sioux Falls metro. The highest CMS rating available locally is ${d.market.topRatedStars}★ (Aetna Value Care and Iowa Health Advantage). More options means matching the plan to your doctors and drugs matters even more.` },
  { q: "Can I keep my Sioux Falls doctors on a NW Iowa Medicare plan?", a: "Often yes — many NW Iowa residents use Sioux Falls health systems (Sanford USD Medical Center, a CMS 5★ hospital, and Avera McKennan at 4★, both ~40 minutes away). Whether they're in-network depends on the plan; we check your specific providers before you enroll." },
  { q: "What health conditions are most common among Sioux County seniors?", a: `Per CDC PLACES (2023), among Sioux County adults high blood pressure affects ${d.health[0].value}%, obesity ${d.health[1].value}%, arthritis ${d.health[2].value}%, and diabetes ${d.health[3].value}%. Each is a reason to check a plan's drug formulary and specialist network.` },
  { q: "Does Big Sioux Benefits serve NW Iowa?", a: "Yes — we're licensed in both South Dakota and Iowa and serve the whole Siouxland region, including Sioux Center, Orange City, and surrounding Sioux County. Our help is free." },
];
const breadcrumbs = [
  { name: "Home", url: site.domain },
  { name: "Locations", url: `${site.domain}/locations` },
  { name: "Sioux Center & NW Iowa", url: `${site.domain}/sioux-center-medicare-plans` },
];
const dataset = { name: SOURCES.cmsLandscape.name + " — Sioux County, IA", description: "Plan counts, premiums, CMS star ratings, county enrollment, and local chronic-condition prevalence for Sioux County (Sioux Center), Iowa.", sourceUrl: SOURCES.cmsLandscape.url };
---
<BaseLayout {title} {description} pageType="location" path="/sioux-center-medicare-plans" {faqs} {breadcrumbs} {dataset}
  place={{ type: "AdministrativeArea", name: "Sioux County", region: "Iowa" }}>
  <section class="section"><div class="wrap">
    <p class="eyebrow">Medicare in NW Iowa · Sioux County, IA</p>
    <h1>2026 Medicare Advantage Plans in <span class="hl">Sioux Center & NW Iowa</span></h1>
    <p style="font-size:1.18rem;max-width:64ch;">
      Just across the Big Sioux, <strong>Sioux County, Iowa has {d.market.stateTotalPlans} Medicare Advantage plans</strong> for 2026 —
      including <strong>{d.market.zeroPremiumCount} at $0 premium</strong> and a top CMS rating of <strong>{d.market.topRatedStars}★</strong>.
      That's more choice than the Sioux Falls side of the border. Below is the real data — plans, local health stats, and
      hospital ratings — plus a live tool to check your ZIP. Big Sioux Benefits is licensed in Iowa and South Dakota.
    </p>
    <p><a class="btn btn-primary" href="/contact">Get a free local plan review →</a></p>
  </div></section>

  <CountyData data={d} />

  <section class="section soft"><div class="wrap"><Tool tool="medicare_plan_finder" defaultZip="51250" heading="See your NW Iowa plans now" sub="Enter your ZIP for an instant count and the top-rated plan — then your full ranked report." /></div></section>

  <section class="section"><div class="wrap" style="max-width:760px;">
    <h2>Choosing a plan in NW Iowa — what matters here</h2>
    <ul>
      <li><strong>More plans, more to compare</strong> — {d.market.stateTotalPlans} options means premium isn't the whole story; the {d.market.topRatedStars}★ plans are worth a close look against your needs.</li>
      <li><strong>Cross-border care</strong> — many residents use Sioux Falls systems (Sanford 5★, Avera 4★); confirm they're in-network.</li>
      <li><strong>Your prescriptions</strong> — Part D drug deductibles range from $300 to $615 across local plans.</li>
      <li><strong>Compare the SD side</strong> — see <a href="/sioux-falls-medicare-plans">Sioux Falls (Minnehaha County) plans →</a></li>
    </ul>
  </div></section>

  <section class="section soft faq"><div class="wrap" style="max-width:820px;">
    <h2>NW Iowa Medicare questions, answered</h2>
    {faqs.map((f) => (<details><summary>{f.q}</summary><p>{f.a}</p></details>))}
  </div></section>

  <section class="section"><div class="wrap" style="text-align:center;">
    <h2>Talk to a local Siouxland Medicare advisor</h2>
    <p class="muted">Free, no pressure — licensed in Iowa and South Dakota.</p>
    <p><a class="btn btn-primary" href="/contact">Book a free consultation →</a> &nbsp; <a class="btn btn-ghost" href={`tel:${site.brand.phoneHref}`}>{site.brand.phone}</a></p>
  </div></section>
</BaseLayout>
