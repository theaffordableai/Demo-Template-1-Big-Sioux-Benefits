---
import BaseLayout from "../layouts/BaseLayout.astro";
import { coverage, education, tools, services } from "../lib/content";
import { site } from "../config/site.config";
// Aggregate every FAQ across the library → one big FAQ page (great for AEO).
const all = [...education, ...coverage, ...tools, ...services].flatMap((e) => e.faqs);
const faqs = all.slice(0, 30);
const breadcrumbs = [{ name: "Home", url: site.domain }, { name: "FAQ", url: `${site.domain}/faq` }];
---
<BaseLayout title="Medicare FAQ — Your Questions Answered | Big Sioux Benefits" description="Answers to the most common Medicare questions for the Sioux Falls area — enrollment, costs, plan types, and more." pageType="article" path="/faq" {faqs} {breadcrumbs}>
  <section class="section"><div class="wrap" style="max-width:820px;">
    <p class="eyebrow">FAQ</p>
    <h1>Medicare questions, answered</h1>
    <p style="font-size:1.18rem;">The questions Sioux Falls-area folks ask us most. Don't see yours? <a href="/contact">Just ask</a> — it's free.</p>
    <div class="faq" style="margin-top:2rem;">
      {faqs.map((f) => (<details><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div></section>
</BaseLayout>
