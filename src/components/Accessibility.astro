---
// Privacy-first accessibility widget (no third-party overlay). Functional controls
// for low-vision seniors; persists via localStorage. Required compliance feature.
---
<button class="a11y-btn" id="a11yBtn" aria-label="Open accessibility tools" aria-expanded="false" title="Accessibility tools">&#9855;</button>
<div class="a11y-panel" id="a11yPanel" role="dialog" aria-label="Accessibility tools" aria-modal="false">
  <h2>Accessibility tools</h2>
  <p class="sub">Adjust the page for easier reading.</p>
  <div class="a11y-grid">
    <button class="a11y-opt" data-mode="text" aria-pressed="false"><span class="i">A&#xFE62;</span>Bigger text</button>
    <button class="a11y-opt" data-mode="contrast" aria-pressed="false"><span class="i">&#9681;</span>High contrast</button>
    <button class="a11y-opt" data-mode="readable" aria-pressed="false"><span class="i">&#128214;</span>Readable font</button>
    <button class="a11y-opt" data-mode="links" aria-pressed="false"><span class="i">&#128279;</span>Highlight links</button>
    <button class="a11y-opt" data-mode="cursor" aria-pressed="false"><span class="i">&#9099;</span>Big cursor</button>
    <button class="a11y-opt" data-mode="noanim" aria-pressed="false"><span class="i">&#9208;</span>Pause motion</button>
  </div>
  <button class="a11y-reset" id="a11yReset">Reset all</button>
</div>
<script is:inline>
(function(){
  var root=document.documentElement, KEY='a11y-prefs';
  var prefs={}; try{prefs=JSON.parse(localStorage.getItem(KEY)||'{}')}catch(e){}
  function apply(){
    root.classList.remove('a11y-text-1','a11y-text-2','a11y-text-3');
    if(prefs.text){root.classList.add('a11y-text-'+prefs.text);}
    ['contrast','readable','links','cursor','noanim'].forEach(function(m){root.classList.toggle('a11y-'+m,!!prefs[m]);});
    document.querySelectorAll('.a11y-opt').forEach(function(b){var m=b.dataset.mode;b.setAttribute('aria-pressed',(m==='text'?!!prefs.text:!!prefs[m])?'true':'false');});
  }
  document.getElementById('a11yBtn').addEventListener('click',function(){var p=document.getElementById('a11yPanel'),o=p.getAttribute('data-open')==='1';p.setAttribute('data-open',o?'0':'1');this.setAttribute('aria-expanded',String(!o));});
  document.querySelectorAll('.a11y-opt').forEach(function(b){b.addEventListener('click',function(){var m=b.dataset.mode;if(m==='text'){prefs.text=((prefs.text||0)+1);if(prefs.text>3)prefs.text=0;}else{prefs[m]=!prefs[m];}localStorage.setItem(KEY,JSON.stringify(prefs));apply();});});
  document.getElementById('a11yReset').addEventListener('click',function(){prefs={};localStorage.setItem(KEY,'{}');apply();});
  apply();
})();
</script>
<style>
  .a11y-btn{position:fixed;left:1.1rem;bottom:1.1rem;z-index:320;width:56px;height:56px;border-radius:50%;border:0;cursor:pointer;background:var(--teal);color:#fff;box-shadow:0 12px 30px -10px rgba(10,34,51,.5);display:grid;place-items:center;font-size:1.7rem;transition:transform .12s}
  .a11y-btn:hover{transform:scale(1.06)}
  .a11y-panel{position:fixed;left:1.1rem;bottom:5rem;z-index:320;width:300px;max-width:calc(100vw - 2.2rem);background:#fff;border:1px solid var(--line);border-radius:16px;box-shadow:0 30px 70px -20px rgba(10,34,51,.5);padding:1rem 1.1rem;display:none}
  .a11y-panel[data-open="1"]{display:block}
  .a11y-panel h2{font-family:var(--body);font-weight:700;font-size:1.05rem;margin:0 0 .2rem}
  .a11y-panel .sub{font-size:.8rem;color:var(--muted);margin:0 0 .8rem}
  .a11y-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem}
  .a11y-opt{display:flex;flex-direction:column;align-items:center;gap:.25rem;padding:.6rem .4rem;border:1.5px solid var(--line);border-radius:11px;background:#fff;cursor:pointer;font:600 .76rem var(--body);color:var(--ink);text-align:center}
  .a11y-opt .i{font-size:1.2rem}
  .a11y-opt[aria-pressed="true"]{border-color:var(--teal);background:var(--teal-l);color:var(--teal-d)}
  .a11y-reset{margin-top:.6rem;width:100%;background:var(--soft);border:1px solid var(--line);border-radius:10px;padding:.5rem;cursor:pointer;font:600 .82rem var(--body);color:var(--ink)}
</style>
