# Cloudflare Pages headers. CSP allows GoHighLevel / LeadConnector widgets
# (chat, voice, calendar, tracking) per GHL-INTEGRATION-STANDARD.md.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://*.leadconnectorhq.com https://*.msgsndr.com https://link.msgsndr.com https://fonts.googleapis.com; connect-src 'self' https://*.leadconnectorhq.com https://*.msgsndr.com wss://*.leadconnectorhq.com; frame-src https://*.leadconnectorhq.com https://*.msgsndr.com; img-src 'self' data: https://*.leadconnectorhq.com https://*.msgsndr.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.leadconnectorhq.com; font-src 'self' data: https://fonts.gstatic.com https://*.leadconnectorhq.com; media-src 'self' https://*.leadconnectorhq.com
